# Optional: only needed for deployment to Polygon or other public RPC networks.
POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/<YOUR_INFURA_PROJECT_ID>

PRIVATE_KEY=<YOUR_PRIVATE_KEY>

CMC_KEY=<YOUR_COINMARKETCAP_API_KEY>

# Optional: enables hardhat-gas-reporter when set to true.
REPORT_GAS=true
